{
  "manifest_version": 3,
  "name": "Xyfy TXT Reader",
  "version": "0.2.1",
  "description": "Local TXT novel reader for Chrome and Edge with book mode, scroll mode, immersive reading, backup, and sync.",
  "permissions": ["storage"],
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Xyfy TXT Reader",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "commands": {
    "open-reader": {
      "suggested_key": {
        "default": "Alt+R",
        "mac": "Command+Shift+R"
      },
      "description": "Open the TXT reader"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["reader/*", "modules/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
