{
  "name": "xyfy-txt-reader",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:zip": "rm -f dist/xyfy-txt-reader-v$npm_package_version.zip && mkdir -p dist && zip -r dist/xyfy-txt-reader-v$npm_package_version.zip . -x 'dist/*' '.git/*' '.github/*' 'node_modules/*' 'tests/*' 'docs/*' 'scripts/*' '*.DS_Store'",
    "gen:icons": "node scripts/gen-icons.mjs",
    "test": "npm run test:paginator && npm run test:backup && npm run test:storage-sync",
    "test:paginator": "node tests/paginator.test.mjs",
    "test:backup": "node tests/backup.test.mjs",
    "test:storage-sync": "node tests/storage-sync.test.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
